"use client"

import { useEffect, useRef, useState, useCallback } from "react"
import { useRouter } from "next/navigation"

type ProviderResult = {
  id: string
  name: string
  slug: string
}

type ExamResult = {
  code: string
  title: string
  providerId: string
  providerSlug: string
  providerName: string
}

type SearchIndex = {
  providers: ProviderResult[]
  exams: ExamResult[]
}

type DropdownItem =
  | { type: "provider"; data: ProviderResult }
  | { type: "exam"; data: ExamResult }

export default function SearchBar() {
  const router = useRouter()
  const [query, setQuery] = useState("")
  const [index, setIndex] = useState<SearchIndex | null>(null)
  const [results, setResults] = useState<DropdownItem[]>([])
  const [open, setOpen] = useState(false)
  const [activeIndex, setActiveIndex] = useState(-1)
  const inputRef = useRef<HTMLInputElement>(null)
  const containerRef = useRef<HTMLDivElement>(null)

  useEffect(() => {
    fetch("/api/search")
      .then((r) => r.json())
      .then((data: SearchIndex) => setIndex(data))
      .catch(() => {})
  }, [])

  useEffect(() => {
    if (!index || !query.trim()) {
      setResults([])
      setOpen(false)
      setActiveIndex(-1)
      return
    }
    const kw = query.toLowerCase().trim()
    const matchedProviders: DropdownItem[] = index.providers
      .filter((p) =>
        p.name.toLowerCase().includes(kw) ||
        p.slug.toLowerCase().includes(kw) ||
        p.id.toLowerCase().includes(kw)
      )
      .map((p) => ({ type: "provider", data: p }))

    const matchedExams: DropdownItem[] = index.exams
      .filter((e) =>
        e.code.toLowerCase().includes(kw) ||
        e.title.toLowerCase().includes(kw) ||
        e.providerName.toLowerCase().includes(kw)
      )
      .map((e) => ({ type: "exam", data: e }))

    setResults([...matchedProviders, ...matchedExams].slice(0, 10))
    setOpen(true)
    setActiveIndex(-1)
  }, [query, index])

  useEffect(() => {
    const handler = (e: MouseEvent) => {
      if (!containerRef.current?.contains(e.target as Node)) setOpen(false)
    }
    document.addEventListener("mousedown", handler)
    return () => document.removeEventListener("mousedown", handler)
  }, [])

  const navigate = useCallback((item: DropdownItem) => {
    if (item.type === "provider") {
      router.push(`/exams/${item.data.slug}`)
    } else {
      router.push(`/exams/${item.data.providerSlug}/${item.data.code}`)
    }
    setQuery("")
    setOpen(false)
    setActiveIndex(-1)
  }, [router])

  const handleKeyDown = (e: React.KeyboardEvent) => {
    if (!open || results.length === 0) return
    if (e.key === "ArrowDown") { e.preventDefault(); setActiveIndex((i) => Math.min(i + 1, results.length - 1)) }
    else if (e.key === "ArrowUp") { e.preventDefault(); setActiveIndex((i) => Math.max(i - 1, -1)) }
    else if (e.key === "Enter") { e.preventDefault(); if (activeIndex >= 0) navigate(results[activeIndex]) }
    else if (e.key === "Escape") { setOpen(false); setActiveIndex(-1) }
  }

  const highlight = (text: string, kw: string) => {
    const idx = text.toLowerCase().indexOf(kw.toLowerCase())
    if (idx === -1) return <span>{text}</span>
    return (
      <>
        {text.slice(0, idx)}
        <mark className="bg-yellow-100 text-black">{text.slice(idx, idx + kw.length)}</mark>
        {text.slice(idx + kw.length)}
      </>
    )
  }

  return (
    <div ref={containerRef} className="flex-1 relative">
      <input
        ref={inputRef}
        type="text"
        value={query}
        onChange={(e) => setQuery(e.target.value)}
        onKeyDown={handleKeyDown}
        onFocus={() => results.length > 0 && setOpen(true)}
        placeholder="Search providers, exam code..."
        className="w-full rounded-full border border-gray-300 px-4 py-1.5 text-sm
                   focus:outline-none focus:ring-2 focus:ring-black"
        autoComplete="off"
      />

      {/* Dropdown */}
      {open && results.length > 0 && (
        <div className="absolute top-full left-0 right-0 mt-1 bg-white border border-gray-200
                        rounded-lg shadow-md z-50 overflow-hidden py-1">

          {/* Providers */}
          {results.some((r) => r.type === "provider") && (
            <>
              <p className="px-3 pt-2 pb-0.5 text-[10px] font-semibold text-gray-400 uppercase tracking-wider">
                Providers
              </p>
              {results.filter((r) => r.type === "provider").map((item) => {
                const globalIdx = results.indexOf(item)
                const p = (item as { type: "provider"; data: ProviderResult }).data
                return (
                  <button
                    key={`p-${p.id}`}
                    onMouseDown={() => navigate(item)}
                    onMouseEnter={() => setActiveIndex(globalIdx)}
                    className={`w-full text-left px-3 py-1.5 flex items-center gap-2 transition
                      ${activeIndex === globalIdx ? "bg-gray-50" : ""}`}
                  >
                    <span className="text-sm"</span>
                    <span className="text-xs font-medium text-gray-800">
                      {highlight(p.name, query)}
                    </span>
                  </button>
                )
              })}
            </>
          )}

          {/* Exams */}
          {results.some((r) => r.type === "exam") && (
            <>
              <p className={`px-3 pb-0.5 text-[10px] font-semibold text-gray-400 uppercase tracking-wider
                ${results.some((r) => r.type === "provider") ? "pt-2 border-t border-gray-100 mt-1" : "pt-2"}`}>
                Exams
              </p>
              {results.filter((r) => r.type === "exam").map((item) => {
                const globalIdx = results.indexOf(item)
                const e = (item as { type: "exam"; data: ExamResult }).data
                return (
                  <button
                    key={`e-${e.providerSlug}-${e.code}`}
                    onMouseDown={() => navigate(item)}
                    onMouseEnter={() => setActiveIndex(globalIdx)}
                    className={`w-full text-left px-3 py-1.5 flex items-center gap-2 transition
                      ${activeIndex === globalIdx ? "bg-gray-50" : ""}`}
                  >
                    <span className="text-sm">📝</span>
                    <div className="min-w-0 flex items-baseline gap-1.5">
                      <span className="text-xs text-gray-700 truncate">
                        {highlight(e.title, query)}
                      </span>
                    </div>
                  </button>
                )
              })}
            </>
          )}

          {/* Footer */}
          <p className="px-3 pt-1.5 pb-1 border-t border-gray-100 mt-1 text-[10px] text-gray-300 flex gap-2">
            <span>↑↓ navigate</span>
            <span>·</span>
            <span>↵ select</span>
            <span>·</span>
            <span>Esc close</span>
          </p>
        </div>
      )}

      {/* No results */}
      {open && query.trim() && results.length === 0 && index && (
        <div className="absolute top-full left-0 right-0 mt-1 bg-white border border-gray-200
                        rounded-lg shadow-md z-50 px-3 py-4 text-center text-xs text-gray-400">
          No results for &ldquo;{query}&rdquo;
        </div>
      )}
    </div>
  )
}
